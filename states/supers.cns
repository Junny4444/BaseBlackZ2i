;================================
; Super Moves
;================================


;--------------------------
;Holy Light Grenade Lvl 1
[Statedef 2200]
type = U
physics = S
movetype = A
anim = stateno+statetype = A
ctrl = 0
velset = 0,0
poweradd = -1000
sprpriority = 1
facep2 = 1



[State 0, Setup]
type = Null
trigger1 = 1 || var(11) := (statetype = A) ;Prevstatetype
trigger1 = 1 || var(31) := 0 ;Charge Time
trigger1 = 1 || var(32) := 70 ;Max Charge Time
trigger1 = 1 || var(33) := 0 ;Superpause Time
trigger1 = 1 || var(34) := 0 ;Sets if Superpause On Or Not 
trigger1 = 1 || fvar(2) := 0.1 ;Scale for Ball
trigger1 = 1 || fvar(3) := 1.1 ;Max Scale For Ball
persistent = 0
ignorehitpause = 1



[State 0, TP SND]
type = PlaySnd
trigger1 = anim = stateno
value = S2302,0
persistent = 0

[State 0, Width]
type = Width
trigger1 = 1
value = 55,0
ignorehitpause = 1



[state 0, Rising Effect]
type = explod
trigger1 = anim = stateno
anim = 1216
pos = 10,12
postype = P1
sprpriority = -3
ownpal = 1
removetime = -2
supermovetime = 9999
pausemovetime = 9999
persistent = 0
ignorehitpause = 0


[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = anim = stateno
statetype = A
persistent = 0
ignorehitpause = 1




[State 0, VelSet]
type = VelSet
trigger1 = anim = stateno && animelemno(0) < 3 
y = -4
persistent = 0

[State 0, VelSet]
type = VelSet
trigger1 = anim = stateno+var(11) && animelemno(0) >= 3
x = 0
y = 0
persistent = 0


[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = anim = stateno+var(11) && animelemno(0) >= 3 && cond(!var(34),1,time < var(33))
flag = noBG
flag2 = noFG

[State 3000, superpause]
type = superpause
trigger1 = anim = stateno+var(11) && animelemtime(3) = 0
trigger1 = 1 || var(33) := time+70 ;Superpause Time
trigger1 = 1 || var(34) := 1
time = var(33)-time+4
p2defmul = 1
unhittable = 1
anim = -1
sound = s2000,0
darken = 0
movetime = var(33)-time+4
persistent = 0


[State 100, "Behold The Power of a God" voice]
type = playsnd
trigger1 = anim = stateno+var(11) && animelemtime(3) = 0
value = 2200,6
channel = 0


[State 200, 1];Death Ball Charge
type = PlaySnd
trigger1 = anim = stateno+var(11) && animelemtime(3) = 0
value = 2200, 8
channel = 1

[State 0, Super FX]
type = Explod
trigger1 = anim = stateno+var(11) && animelemtime(3) = 0
anim = 2003
id = 2003
pos = 20,-150
postype = p1
supermovetime = 9999
pausemovetime = 9999
removetime = -2
sprpriority = 8
ownpal = 1
bindtime = -1
scale = 1,1
persistent = 0



[State 0, Charge FX]
type = Explod
trigger1 = anim = stateno+var(11) && animelemtime(3) = 0
anim = stateno+2
ID = stateno+2
postype = P1
pos = 20,-150
bindtime = -1
removetime = -1
removeongethit = 1
sprpriority = 9
supermovetime = 9999
persistent = 0
scale = fvar(2),fvar(2)



[State 0, Scale Ball]
type = ModifyExplod
trigger1 = numexplod(stateno+2)
trigger1 = fvar(2) <= fvar(3)
trigger1 = 1 || fvar(2) := fvar(2)+0.009
ID = stateno+2
scale = fvar(2),fvar(2)

[State 0, Add To Charge Time]
type = Null
trigger1 = var(31) <= var(32)
trigger1 = time >= var(33) ;Superpause Over
trigger1 = 1 || var(31) := var(31)+1
ignorehitpause = 1



[State 0, Throw Ball]
type = ChangeAnim
trigger1 = time >= var(33) && var(34) ;Superpause Over
trigger1 = (command != "holdx") && (command != "holdy") && (command != "holdz") || var(31) >= var(32) ;Charge Time MAX
value = stateno+5
persistent = 0


[State 100, "Death Ball" voice]
type = playsnd
trigger1 = anim= stateno+5
value = 2200,7
channel = 0
persistent = 0



[State 0, Change Ball Pos]
type = ModifyExplod
triggerall = anim = stateno+5
trigger1 = Numexplod(stateno+2)
ID = stateno+2
postype = P1
pos = 25,-115
persistent = 0


[State 0, Remove Charge Ball]
type = RemoveExplod
trigger1 = anim = stateno+5
trigger1 = animelemtime(2) = 0
trigger1 = Numexplod(stateno+2)
id = stateno+2
ignorehitpause = 1
persistent = 0


[State 0, Helper]
type = Helper
trigger1 = anim = stateno+5
trigger1 = animelemtime(2) = 0
trigger1 = !Numhelper(stateno+10)
stateno = stateno+10
ID = stateno+10
postype = P1
name = "Holy Light Grenade"
pos = 0,0
size.head.pos = 30+(var(31)/3),3 ;DMG, then Armor Hits
size.mid.pos = 7,7 ;Vel X and Y
size.height = stateno+10 ;Anim
persistent = 0



[State 0, ChangeState]
type = ChangeState
trigger1 = anim = stateno+5 && !animtime
value = stateno+3
ctrl = 0


