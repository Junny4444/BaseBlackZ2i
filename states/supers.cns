trigger1 = 1 || fvar(5) := 2212 ;Actual Ball Anim
trigger1 = 1 || fvar(2) := 0.6 ;Scale for Ball
trigger1 = 1 || fvar(3) := 1 ;Max Scale For Ball
trigger1 = 1 || fvar(6) := 6 ;Armor Hits
trigger1 = 1 || fvar(7) := 60 ;DMG
trigger1 = 1 || var(52) := 25 ;Pos X Hold
trigger1 = 1 || var(53) := -180 ;Pos Y Hold
persistent = 0
ignorehitpause = 1

