trigger1 = Numexplod(90000210) && Numexplod(90000220)
triggerall = !var(9) ;Zamasu Var
triggerall = var(50) >= 1 ;Emo on
triggerall = var(51) >= 200
triggerall = !Numhelper(3300)
trigger1 = 1 || var(36) := var(36) + 131072
