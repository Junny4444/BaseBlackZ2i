movetype = I
ctrl = 0
anim = stateno
velset = 0,0



[State 0, PosSet]
type = PosSet
trigger1 = 1
y = 0


[State 0, Landing Sound]
type = PlaySnd
trigger1 = 1
value = 40, 0
persistent = 0

[state 0, Land FX]
type = helper
trigger1 = 1
name = "LandFX"
StateNo = 17100
id = 17100
postype = P1
ownpal = 1
keyctrl = 0
supermovetime = 99999
pausemovetime = 99999
persistent = 0


[State 0, ChangeState]
type = ChangeState
trigger1 = !animtime
value = 0
ctrl = 1
