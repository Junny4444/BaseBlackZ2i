[Statedef 2203]
type = A
physics = N
movetype = A
ctrl = 0
anim = 44
velset = 0,0




[State 0, VelAdd]
type = VelAdd
trigger1 = 1 
y = .45



[State 0, Land]
type = ChangeState
trigger1 = pos y >= 0 && vel y > 0
value = stateno+1
ctrl = 0



;Light Grenade Land
[Statedef 2204]
type = S
