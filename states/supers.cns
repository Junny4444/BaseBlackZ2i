;Light Grenade Projectile
[Statedef 2210]
type = A
movetype = A
physics = N
ctrl = 0

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow
ignorehitpause = 1


[State 0, Setup]
type = Null
triggerall = !prevstateno
trigger1 = 1 || var(1) := const(size.head.pos.y) ;Hitcount/Armor Hits
trigger1 = 1 || var(2) := 0 ;Hitcount Var for counting
trigger1 = 1 || var(3) := const(size.height) ;Anim
trigger1 = 1 || var(4) := const(size.head.pos.x) ;DMG
trigger1 = 1 || var(5) := const(size.mid.pos.x) ;Vel X
trigger1 = 1 || var(6) := const(size.mid.pos.y) ;Vel Y
ignorehitpause = 1
persistent = 0


[State 0, Anim Setup]
type = ChangeAnim
trigger1 = !prevstateno
trigger1 = anim != var(3)
value = var(3)


[State 0, BindToRoot]
type = BindToRoot
trigger1 = !prevstateno
time = 1
pos = 60,-40
ignorehitpause = 1
persistent = 0


[State 0, Light Grenade toss]
type = playsnd
trigger1 = !prevstateno
value = cond(var(3) = 2210,2200,2820),cond(var(3) = 2210,0,1)
persistent = 0
volumescale = cond(var(3) = 2210,100,150)

[State 0, VelSet]
type = VelSet
trigger1 = 1 
x = var(5)
y = var(6)
persistent = 0


[State 0, VelMul]
type = VelMul
trigger1 = movecontact
x = .5
y = .5
ignorehitpause = 1


[State 0, Add to Armor Hits]
type = Null
trigger1 = prevstateno 
trigger1 = 1 || var(2) := var(2)+1
persistent = 0
ignorehitpause = 1


[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,AA,AT
time = 1

[State 0, HitBy]
type = HitBy
trigger1 = 1
value = SCA,AP
time = 1


[State 0, HitOverride]
type = HitOverride
trigger1 = 1
attr = SCA,AP
stateno = stateno
time = 1



[State 0, Projectile]
type = Projectile
trigger1 = (P2BodyDist X = [-90,90]) && (P2BodyDist Y = [-90,90])
ProjID = 93999999999
projanim = 1
projremovetime = 2
offset = -400,0
postype = p1
attr = S,SP        ;change this to whatever your projectile is set
ignorehitpause = 1
guardflag = MA
guard.dist = 1999
projedgebound = 1600
projstagebound = 1600


[State 0, Time]
type = Null
trigger1 = 1 || var(0) := var(0)+1 


[State 0, Scale DMG]
type = Null
trigger1 = Movehit = 1
trigger1 = 1 || root,cond(1,fvar(13) := fvar(13) + 3,0) ;Scales Damage 



[State 1315, image]
type = afterimage
trigger1 = !prevstateno
time = -1
timegap = 1
framegap = 2
length = 5
palcontrast = 50,50,200
trans = add

[State 3005, hit]
type = hitdef
trigger1 = 1
attr = A,HP
hitflag = MAFD
guardflag = MA
priority = 7,Hit
damage = ceil(cond(root,fvar(11) * var(4) < 7, 7, (root,fvar(11)) * var(4))), 4
getpower = 0,0
givepower = 35,35
pausetime = 6,6
animtype = Back
air.animtype = Back
fall.animtype = Back
ground.type = Low
air.type = Low
ground.hittime = 16
ground.slidetime = 16
guard.hittime = 16
air.hittime = 13
airguard.ctrltime = 16
ground.velocity= cond(var(2)< var(1), -1, -6), cond(var(2)< var(1), -3, -6)
guard.velocity = -8
air.velocity = -5,6
airguard.velocity = -4, 2.5 
down.velocity = 0,0
down.hittime = 20
ground.cornerpush.veloff = 0
guard.cornerpush.veloff = 0
air.cornerpush.veloff = 0
airguard.cornerpush.veloff = 0
yaccel = .5
fall=1
air.fall = 1
fall.recover = 0
fall.recovertime = 13
sparkno = -1
hitsound   = s2205,20 ;s1000,0
guardsound = S6,0
envshake.time = 16
envshake.ampl = 6
envshake.freq = 100
forcestand = 1
palfx.sinadd=64,64,64,4
palfx.mul=128,128,128
palfx.time=32
p1sprpriority = 5



[State 0, ChangeState]
type = ChangeState
trigger1 = movecontact
trigger2 = var(2) >= var(1)
trigger3 = pos y >= -10 && vel y > 0
value = cond(var(2) >= var(1),stateno+1,stateno)
ctrl = 0
ignorehitpause = 0




