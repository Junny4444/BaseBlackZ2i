ctrl = 0

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,0

[State 0, Turn On Continue Bit]
type = Null
triggerall = (var(36)&4096) = 0
triggerall = movehit
triggerall = command = "holda" || command = "holdb" || command = "holdc"
triggerall = var(50) ;Emo On
triggerall = var(51) >= 200 ;Enough Bar
trigger1 = 1 || var(36) := var(36) + 4096
persistent = 0


[State 0, LTG Lightning]
type = PlaySnd
trigger1 = !time
value = 1400,20
persistent = 0
channel = 4


[State 0, Emo Usage FX]
type = Explod
triggerall = !Numexplod(910)
trigger1 = !time
anim = 910
ID = 910
postype = P1
pos = 5,-60
sprpriority = 3
persistent = 0
bindtime = -1
supermovetime = 9999

[State 0, Remove Emo]
type = VarAdd
trigger1 = !time
var(51) = -200


[State 0, HitDef]
type = HitDef
triggerall = anim = 2501
trigger1 = !movecontact
attr = A, HA
damage = Ceil(cond(fvar(11) * 149 < 107, 107, fvar(11) * 149)), 25
animtype = Hard 
guardflag = MA
hitflag = MAFD
priority = 4, Hit
pausetime = 0, 0
guard.pausetime = 0, 0
sparkno = s7031
guard.sparkno = s7001
hitsound = -1
guardsound = -1
ground.type = High
air.type = High
ground.slidetime = 16
ground.hittime = 16
ground.velocity = -2, 0
guard.velocity = -10
air.velocity = 0, 20
ground.cornerpush.veloff = 0
guard.velocity = -10.52
guard.cornerpush.veloff = 0
getpower = 0
givepower = 36, 36
envshake.time = 18
envshake.freq = 120
envshake.ampl = 6
fall = 1
fall.recover = 0
airguard.ctrltime = 16
airguard.velocity = ifelse(var(20), -4, -8), -1.5
forcestand = 1
ID = 2350


;Custom Stab State
[State 0, Targetstate]
type = TargetState
trigger1 = NumTarget(2350)
trigger1 = movehit = 1
value = ifelse(target,statetype = A, 2505, 2500)
ignorehitpause = 0
persistent = 0

[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = Pos Y>=0
statetype = S    


[State 4100, Pos]
