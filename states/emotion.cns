persistent = 0


[State 0, Hitground SND]
type = PlaySND
trigger1 = pos y >= 0 
value = 5,7
persistent = 0

[State 0, TP]
type = ChangeAnim
triggerall = movehit && (var(36)&4096) != 0
trigger1 = Anim = cond((var(36)&4096) = 0,2502,2502000) && !animtime
trigger1 = 1 || var(36) := var(36) - (var(36)&4096)
value = 2504

[State 0, ChangeState];Decides if he does the 3rd followup or not
type = ChangeState
triggerall = !movehit || movehit && (var(36)&4096) = 0
trigger1 = Anim = cond((var(36)&4096) = 0,2502,2502000) && !animtime
value = 0
ctrl = 1 

[State 2200, teleport fx snd]
type = PlaySnd
trigger1 = anim = 2504
value = 2302,0
persistent = 0


[State 0, Last Time]
type = ChangeState
trigger1 = Anim = 2504 && !animtime
value = 2352



