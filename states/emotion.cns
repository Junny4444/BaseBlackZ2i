;JUDGEMENT MODE EXIT
[Statedef 4100]
type = S
movetype = I
physics = S
anim = 4100
ctrl = 0



[State 0, Init Finisher Attempt Bit]
type = Null
triggerall = (var(39)&1) = 0
trigger1 = 1 || var(39) := var(39) + 1
persistent = 0


[State 3900, voice]
type = PlaySnd
trigger1 = AnimElem = 1
value = 0, 104 
channel = 6

;----Common Superpause Effects ------------
[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = Time >= 17 && Time < 60
flag = noBG
flag2 = noFG

[State 1000, shake]
type = EnvShake
trigger1 = Time >=17 && Time <=47
trigger1 = !(time%4)
time=4
freq=80
ampl=1.5+0.02*time


[State 3000, superpause]
type = superpause
triggerall = var(50)
triggerall = Animelem = 5 
trigger1 = var(51) < 300 ;LVL 0
trigger1 = 1 || var(35) := 90
trigger2 = var(51) >= 300 && var(51) < 600 ;LVL 1
trigger2 = 1 || var(35) := 180
trigger3 = var(51) >= 600 && var(51) < 998 ;LVL 2
trigger3 = 1 || var(35) := 275
trigger4 = var(51) >= 999 ;LVL 3
trigger4 = 1 || var(35) := 450
time = 60
p2defmul = 1
unhittable = 1
anim = -1
sound = s2000,0
darken = 0
movetime = 60
persistent = 0

[State 0, Set Emo to 0]
type = Null
trigger1 = Animelem = 5
trigger1 = 1 || var(50) := 0 || var(51) := 0
persistent = 0

[State 0, Super FX]
type = Explod
trigger1 = time = 17
anim = 2003
id = 2003
pos = 5,-80
postype = p1
supermovetime = 9999
pausemovetime = 9999
removetime = -2
sprpriority = 8
ownpal = 1
bindtime = -1
scale = 1,1
persistent = 0


[State 0, Zamasu Heal]
type = Helper
triggerall = !Numhelper(3400)
trigger1 = animelemtime(6) >= 0
stateno = 3400
ID = 3400
name = "Zamasu Heal Helper"
pos =0,0
postype = p1
keyctrl = 0
ownpal = 1
persistent = 0

[State 0, Heal Fail]
type = ChangeState
trigger1 = animelemtime(6) >= 0
trigger1 = var(9) = 2
value = 4105
ctrl = 0



[State 0, Heal FX]
type = PalFX
trigger1 = AnimElem = 24
time = 22
add = 0,100,50
mul = 20,220,24
sinadd = 85,110,55,20
invertall = 0
color = 0

[State 3900, thank u]
type = PlaySnd
trigger1 = AnimElem = 25
value = 0, 105 
channel = 6


[State 0, Lifeadd]
type = Lifeadd
triggerall = NumHelper(3400)
trigger1 = stateno = 4100
trigger1 = Animelem = 24
value = var(35)





[State 0, ChangeState]
type = ChangeState
trigger1 = !animtime
value = 0
ctrl = 1

