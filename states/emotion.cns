;ScreenBound Helper
[Statedef 4205]
type = A
physics = N
anim = 1

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,1



[State 0, Init]
type = Null
trigger1 = 1 || var(2) := Ishelper(4206) 
trigger1 = 1 || var(0) := root,id || var(1) := parent,id
trigger1 = 1 || var(59) := root,stateno
persistent = 0


[State 0, Left Bound]
type = PosAdd
trigger1 = !var(2)
x = -screenpos X
y = floor(-screenpos Y + gameheight)
ignorehitpause = 1

[State 0, Right Bound]
type = PosAdd
trigger1 = var(2)
x = floor(-screenpos X + gamewidth)
y = floor(-screenpos Y + gameheight)
ignorehitpause = 1


[State 0, DestroySelf]
type = DestroySelf
trigger1 = root,stateno != var(59)
trigger1 = root,stateno != var(59) + 50


