;JUDGEMENT MODE ACTIVATE
[Statedef 4000]
type = S
movetype = I
physics = S
anim = 4000
ctrl = 0
velset = 0,0
sprpriority = 1
poweradd = -2000

[State 0, Activate Emo]
type = VarSet
trigger1 = 1
var(50) = 1
persistent = 0

[state 17100, Judgement Mode face]
type = explod
trigger1 = AnimElem = 2
anim = 4002
id = 4002
pos = 0,0
postype = P1
sprpriority = 3
ownpal = 1
supermovetime = -1
removetime = -2
persistent = 0
bindtime = -1

[State 200, BGPalFX]
type = BGPalFX
trigger1 = animelemtime(7)>=0
time = 1
add	= -100,-100,-100
mul	= 100,100,256
invertall = 0
color = 256



[State 3000, superpause]
type = superpause
trigger1 = 1
time = 152
p2defmul = 1
unhittable = 1
anim = -1
sound = s2350,2
darken = 0
movetime = 152
persistent = 0

[State 13100, shake]
type = envshake
trigger1 = animelemtime(7)>=0
trigger1 = !(time%12)
time = 12
freq = 5
ampl = 2

[State 4500, 1];Scream
type = PlaySnd		
trigger1 = animelemtime(5)=0
value = 12,2
volume = 500
channel = 0
[State 4500, 1];power up SFX
type = PlaySnd
trigger1 = animelemtime(7)=0
value = 193,1
volume = 500
channel = 9

[State 1003, Helper]
type = Helper
trigger1 = AnimElemTime(7)=1
trigger2=AnimElemTime(7)>1&&time%5=0
helpertype = Normal
name = "Ball Effect"
id = 4001
pos =((random%Const(Size.Ground.Front))-5),((random%Const(Size.Height))-50)
postype = p1
facing = 1
stateno = 4001
keyctrl = 0
ownpal = 1
supermovetime = 9999
pausemovetime = 9999
ignorehitpause = 1
size.xscale = .02 
size.yscale = .02
[State 1003, Helper]
type = Helper
trigger1 = AnimElemTime(7)=1
trigger2=AnimElemTime(7)>1&&time%40=0
helpertype = Normal
name = "Ball Effect"
id = 4001
pos =((random%Const(Size.Ground.Front))-5),0
postype = p1
facing = 1
stateno = 4001
keyctrl = 0
ownpal = 1
supermovetime = 9999
pausemovetime = 9999
ignorehitpause = 1
size.xscale = .04 
size.yscale = .04
[State 1003, Helper]
type = Helper
trigger1 = AnimElemTime(7)=1
trigger2=AnimElemTime(7)>1&&time%80=0
helpertype = Normal
name = "Ball Effect"
id = 4001
pos =((random%Const(Size.Ground.Front))-5),0
postype = p1
facing = 1
stateno = 4001
keyctrl = 0
ownpal = 1
supermovetime = 9999
pausemovetime = 9999
ignorehitpause = 1
size.xscale = .06
size.yscale = .06

[State 1900,Breakaway FX]
type = explod
trigger1 =animelemtime(5)=0&&!NumExplod(4001)
anim = 4001
id = 4001
pos = 0,0
sprpriority = 4
bindtime = -1
ownpal = 0
removeongethit = 1
ignorehitpause = 1
facing = 1
removetime = -1
pausemovetime = 99999
supermovetime = 99999

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time>=61
id = 4001

;[State 0, Debug Emo Values]
;type = Null
;triggerall = var(50)
;trigger1 = 1 || var(51) := 600
;persistent = 0


[State 3000, end]
type = changestate
trigger1 = !AnimTime
value = 0
ctrl = 1

