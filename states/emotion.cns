;Tandem is a sequence of pre-input commands that the helper/stand performs back to back in sequence
;
;Sequence can be handled via the vars of a helper
;We need to be able to write into the sequence, and in order based on our input
;Either use a fvar in the helper, or use a temp var in the root in order to index into the sequence
;
;Let's say command = x
;var(x) = 200
;var(y) = 0 ;Beginning value of Index
;
;trigger1 = var(x) && var(y) < 20
;trigger1 = 1 || helper(x),cond(1,var(root,var(y)) := root,var(x),0)
;trigger1 = 1 || var(y) := var(y) + 1
;var(x) = 0
;
;The helper then goes to a "waiting" state where it evaluates whether or not to perform an action
;
;fvar(0) = 0 ;Local index into the sequence
;
;Increment the fvar(0) (the index) by 1 every time we enter this state in order to ensure the sequence is played in order
;
;varadd
;fvar(1) = 1
;
;changestate
;trigger1 = var(floor(fvar(0)-1)) != 0 && time = 4
;value = stateno+(var(floor(fvar(0)-1)))
;
;Ensure we end if either the index is >= 60 or if the number in the current index is 0
;trigger1 = fvar(0) > 60 || var(floor(fvar(0)-1)) = 0
;value = (endstate)


