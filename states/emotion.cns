[State 0, Stop]
type = Posset
triggerall = anim = 2501
trigger1 = Pos Y>=0
y = 0
ignorehitpause = 0
persistent = 1

[State 0, Stop]
type = Velset
triggerall = anim = 2501
trigger1 = Pos Y>=0
y = 0
ignorehitpause = 0
persistent = 1


[State 0, Get Ready Again]
type = ChangeAnim
trigger1 = Pos Y>=0
value = cond((var(36)&4096) = 0,2502,2502000)
