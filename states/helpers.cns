;NEW DIZZY CODE
[State Set Dizzy Vars]
type = Null
triggerall = numenemy
;3/4 = Enemy 0 Dizzy Timer/Buffer
;7 = Dizzy SND 1
;ENEMY 0
trigger1 = enemy(0),stateno = 1321
trigger1 = 1 || var(3) := 130 ;Timer 1
trigger1 = 1 || var(4) := 0 ;Reset Dizzy Tap Buffer

[State Set Dizzy Vars]
type = Null
triggerall = numenemy=2
;5/6 = Enemy 1 Dizzy Timer/Buffer
;8 = Dizzy SND 2
;ENEMY 1
trigger1 = enemy(1),stateno = 1321
trigger1 = 1 || var(5) := 130 ;Timer 2
trigger1 = 1 || var(6) := 0 ;Reset Dizzy Tap Buffer

[State Dizzy Timer Passive Decrement]
type = Null
triggerall = numenemy
;ENEMY 0
trigger1 = enemy(0),stateno = 5300
trigger1 = 1 || var(3) := var(3) - 1 ;Timer 1
[State Dizzy Timer Passive Decrement]
type = Null
triggerall = numenemy=2
;ENEMY 1
trigger1 = enemy(1),stateno = 5300
trigger1 = 1 || var(5) := var(5) - 1 ;Timer 1

[State Enemy 0 Decrrement Timer/Increment Buffer via button presses]
type = Null
triggerall = numenemy
triggerall = enemy(0),stateno=5300 && var(3)
trigger1 = enemy(0),command = "up" || enemy(0),command = "down" || enemy(0),command = "back" || enemy(0),command = "fwd"
trigger1 = 1 || var(3) := var(3) - 2 || var(4) := var(4) + 1 ;Add to Tap Buffer too
trigger2 = enemy(0),command = "x" || enemy(0),command = "y" || enemy(0),command = "z" || enemy(0),command = "a" || enemy(0),command = "b" || enemy(0),command = "c"
trigger2 = 1 || var(3) := var(3) - 1 || var(4) := var(4) + 1 ;Add to Tap Buffer too
trigger3 = enemy(0),animelemtime(1) >= 0 && !(enemy(0),animelemtime(enemy(0),animelemno(0)))
trigger3 = 1 || var(4) := 0 ;Reset Skip Anim Buffer

[State Enemy 1 Decrrement Timer/Increment Buffer via button presses]
type = Null
triggerall = numenemy=2
triggerall = enemy(1),stateno=5300 && var(5)
trigger1 = enemy(1),command = "up" || enemy(1),command = "down" || enemy(1),command = "back" || enemy(1),command = "fwd"
trigger1 = 1 || var(5) := var(5) - 2 || var(6) := var(6) + 1 ;Add to Tap Buffer too
trigger2 = enemy(1),command = "x" || enemy(1),command = "y" || enemy(1),command = "z" || enemy(1),command = "a" || enemy(1),command = "b" || enemy(1),command = "c"
trigger2 = 1 || var(5) := var(5) - 1 || var(6) := var(6) + 1 ;Add to Tap Buffer too
trigger3 = enemy(1),animelemtime(1) >= 0 && !(enemy(1),animelemtime(enemy(1),animelemno(0)))
trigger3 = 1 || var(6) := 0 ;Reset Skip Anim Buffer

[State Slide snd]
type = playsnd
triggerall = numenemy
trigger1 = var(7) = 1
trigger1 = 1 || var(7) := 0
trigger2 = var(8) = 1
trigger2 = 1 || var(8) := 0
value = 5,8

[State Dizzy Snd]
type = playsnd
triggerall = numenemy
trigger1 = var(7) = 2
trigger1 = 1 || var(7) := 0
trigger2 = var(8) = 2
trigger2 = 1 || var(8) := 0
value = 2522, ifelse(random < 500, 0, 1)  ;Dizzy sounds. 
;End dizzy code 5.0
