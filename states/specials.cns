;God Slicer (236MP)
[Statedef 1000]
type    = A
movetype= A
physics = S
ctrl = 0
anim = 1000
velset = 0,0
sprpriority = 0


[State 0, Set Offset For Timing]
type = Null
trigger1 = 1 || fvar(4) := 13 ;How Many Startup Frames before leaving ground
persistent = 0


[State 0, NotHitBy]
type = NotHitBy
trigger1 = Time > 2
value = A,AA
time = 1
ignorehitpause = 1


[State 0, HitBy]
type = HitBy
trigger1 = Time > 2
value = SC,AA,AP,AT
time = 1
ignorehitpause = 1

[State 0, NOT GETTING AWAY!!!]
type = PlaySnd
triggerall = AnimElem = 2
trigger1 = random<500
value = 0, 102
channel = 0

[State 0, Width]
type = Width
trigger1 = animelemtime(2) >= 0
value = 55,10

[state 1215, Smoke FX]
type = explod
trigger1 = !time
anim = 1206
id = 1206
pos = -10,0
postype = P1
sprpriority = 3
ownpal = 1
removetime = -2
persistent = 0
ignorehitpause = 1
scale = .8,.8

[State 0, VelSet]
type = VelSet
trigger1 = Time = fvar(4)
x = 2
y = -3.8

[State 0, Veladd]
type = VelAdd
trigger1 = Time = fvar(4)+1
y = -0.25

[State 0, Veladd]
type = VelAdd
trigger1 = Time >= fvar(4)+2
x = 0.65
y = 0.19

[State 0, Ki Blast]
type = Helper
trigger1 = time = fvar(4)+3 || time = fvar(4)+9 || time = fvar(4)+13 || time = fvar(4)+20
name = "Ki Blast"
ID = 1010
stateno = 1010
pos = 65,-45
postype = p1
facing = 1
keyctrl = 0
ownpal = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = fvar(4)+3 || time = fvar(4)+9 || time = fvar(4)+13 || time = fvar(4)+20
value = S10,0
volumescale = 45
channel = 1

[State 200, End]
type = Changestate
trigger1 = Time >= fvar(4)+23
value = 1001



;-------------------------------------------------------------------------------
;God Slicer - Swing
[Statedef 1001]
type    = A
movetype= A
physics = N
juggle  = 4
ctrl = 0
anim = 1001
sprpriority = 0

[State add to bar]
type = varset
triggerall = var(50)>=1
trigger1 = movehit
var(51) = cond(var(51)+50 >= 999,999,var(51)+50)
persistent = 0
ignorehitpause = 1

;animate through blur anim on hitpause code (only use this if an attack can hit on a blur frame) this will be the only example given
    [State 200, Time Offset]
    type = VarSet
    trigger1 = moveContact = 1
    var(15) = Time
    ignorehitpause = 1
    persistent = 0

    [State 200, Play Anim]
    type = ChangeAnim
    triggerall = AnimElemTime(3) >= 0 && AnimElemTime(4) <= 0 ;(2)would be the blur frame while (3) is the nonblur
    trigger1 = hitPauseTime = [1,8 - (1 - var(15))] ;[1,10 - (5 - var(15))] means [1,10 {change the 10 to the hitpausetime} - (5 {change the 5 to how long it takes before you get to the frame you want the pause to stay on}- var(15))]
    value = anim
    elem = 4
    ignorehitpause = 1
;end blur code



