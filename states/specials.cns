;------------------------------------
;Black 2nd Attack
[StateDef 1102]   
type = A          
movetype = A     
physics = N       
anim = 1102  
sprpriority = 4





[State 0, Init]
type = Null
trigger1 = 1 || var(35) := 0 ;Scratch Var
trigger1 = 1 || var(36) := var(36) - (var(36)&2048) ;Reset P2 State Check
persistent = 0


[State 0, Scratch Varadd]
type = Null
triggerall = animelemno(0) = [2,3]  
trigger1 = 1 || var(35) := time
persistent = 0


[State 0, Pullback]
type = Offset
triggerall = facing = 1
trigger1 = animelemno(0) = [2,3]
;trigger1 = animelemno(0) = 2
;trigger1 = Animelemtime(2) >= 0 && Animelemtime(3) < 0
y = floor(-2.5 * (time-var(35)))
x = floor(-2.8 * (time-var(35)))
;ignorehitpause = 
;persistent = 

[State 0, Pullback]
type = Offset
triggerall = facing = -1
trigger1 = animelemno(0) = [2,3]
y = floor(-2.5 * (time-var(35)))
x = floor(2.8 * (time-var(35)))


;[State 0, Pullback]
;type = Offset
;trigger1 = animelemno(0) = 3
;;trigger1 = Animelemtime(3) >= 0 && Animelemtime(4) < 0
;y = -10
;x = -8
;ignorehitpause = 1
[State 0, Offset]
type = Offset
;trigger1 = animelemtime(4) >= 0
trigger1 = animelemno(0) = 4
y = -14
x = -12    
ignorehitpause = 1  

[State 0, EnvShake]
type = EnvShake
trigger1 = movehit = 1
time = 10
ampl = -4
ignorehitpause = 1

[State 282, hit]
type = hitdef
triggerall = anim = 1104 || anim = 1104000
trigger1 = AnimElem = 4
attr = A,SA
damage = ceil(ifElse(fvar(11) * 25 < 7, 7, fvar(11) * 25)), 2
animtype = Hard
guardflag = HA
hitflag = MAFD
priority = 4,Hit
pausetime = 11,12 
sparkno = s7030
guard.sparkno = s7000
sparkxy = -30,-18
hitsound = s5,7
guardsound = S6,0
ground.type = High
ground.hittime = 15
ground.slidetime = 15
ground.velocity = -4,-6.5
air.type = Low
air.velocity = -3,-5
down.hittime = 24
down.velocity = 0,0
air.cornerpush.veloff = 0
getpower = ifelse(p2movetype=H,40,140), 35
givepower = 35,35
yaccel = .5
fall = 1
p1sprpriority = 4
ID = 1102

