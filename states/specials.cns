trigger1 = NumTarget
trigger1 = !(target,ishelper)
trigger1 = movehit
value = cond((var(36)&1) = 0,1108,1109)
ID = 1102
ignorehitpause = 1
persistent = 1


[State 0, Ground Crack FX]
type = Explod
triggerall = numtarget
triggerall = !Numexplod(1103)
trigger1 = movehit = 1
anim = 1103
ID = 1103
pos = floor(abs(pos x - target, pos x) + 10),5
postype = p1
scale = 1.0,1.0
sprpriority = -9
ontop = 0
ownpal = 1
ignorehitpause = 1


[State 0, VelSet]
type = VelSet
trigger1 = pos y < -10
x = 14
y = 13
persistent = 0

[State 1110, P2 Dust FX]
type = explod
triggerall = !numexplod(1206) 
trigger1 = pos y >=-10
id = 1206
anim = 1206
postype = P1
pos = 0,0
ontop = 0
sprpriority = -4
persistent = 0



[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = pos y >= -10
value = cond( (var(36)&1) = 0,1104,1104000) ;Changes Divekick anim speed if limiter is on
ignorehitpause = 1
persistent = 0

[State 0, VelSet]
type = VelSet
trigger1 = pos y >= -10
x = 8.5
y = 0
persistent = 0


[State 0, Momentum]
type = VelSet
trigger1 = pos y >= -10
x = cond(vel x > 0,vel x - .25,0)



[State 0, PosSet]
type = PosSet
trigger1 = pos y >= -10
y = 13



[State 0, TargetBind]
type = TargetBind
trigger1 = !movehit
pos = 20,-10
ignorehitpause = 1



[State 0, Flip Back]
type = Changestate
trigger1 = movehit 
trigger1 = 1 || var(36) := var(36) + 1*((var(36)&1)=0) ;Sets Limiter
value = 1103
ctrl = 0
ignorehitpause = 0


[State 0, Move Slower]
type = Velset
trigger1 = !numtarget
y = vel y / 5
persistent = 0

[State 0, End]
type = Changestate
trigger1 = !numtarget
value = 50
ctrl = 0


