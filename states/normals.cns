; TAUNT
[Statedef 195]
type = S
movetype = I
physics = S
ctrl = 0
anim = 195
velset = 0,0
sprpriority = 1



[state 195, voice]
type = playsnd
trigger1 = !time 
value = 195,10+random%2
channel = 0

[State 200, VS vegeta]
type = PlaySnd
triggerall = !time
trigger1 = (var(36)&4) != 0 ;Checks if Vegeta is in the match (check config for more details)
value = 195,12
channel = 0

[State 1057, transform]
type = PlaySnd
trigger1 = Time = 5
value = 195,1
channel = 1


[State 1057, detransform]
type = PlaySnd
trigger1 = Time=95 
value = 30300,0
channel = 1

;[State 0, Set Emo Vars]
;type = Null
;trigger1 = 1 || var(51) := 999
;persistent = 0


[State 195, 2]
type = ChangeState
trigger1 = !AnimTime
value = 0
ctrl = 1


