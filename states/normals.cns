;---------------------------------------------------------------------------
; 6HP (Emo Exclusive)
[Statedef 225]
type = S
movetype = A
physics = S
anim = 225
ctrl = 0
;velset = 0,0
sprpriority = 1
juggle = 7

[State 0, Set Usage Flag]
type = Null
trigger1 = (var(36)&64) = 0
trigger1 = 1 || var(36) := var(36) + 64
persistent = 0


[State add to bar]
type = varset
triggerall = var(50)>=1
trigger1 = movehit
var(51) = cond(var(51)+65 >= 999,999,var(51)+65)
persistent = 0
ignorehitpause = 1

[State 0, PosAdd]
type = PosAdd
trigger1 = AnimElem = 5
x = 10

;animate through blur anim on hitpause code (only use this if an attack can hit on a blur frame) this will be the only example given
    [State 200, Time Offset]
    type = VarSet
    trigger1 = moveContact = 1
    var(15) = Time
    ignorehitpause = 1
    persistent = 0

    [State 200, Play Anim]
    type = ChangeAnim
    triggerall = AnimElemTime(5) >= 0 && AnimElemTime(6) <= 0 ;(2)would be the blur frame while (3) is the nonblur
    trigger1 = hitPauseTime = [1,13 - (1 - var(15))] ;[1,10 - (5 - var(15))] means [1,10 {change the 10 to the hitpausetime} - (5 {change the 5 to how long it takes before you get to the frame you want the pause to stay on}- var(15))]
    value = anim
    elem = 6
    ignorehitpause = 1
;end blur code

[State 200, 1];voice
type = PlaySnd
trigger1 = animelem=5 && random<500
value = 3,105+random%2
channel = 0

[State 220, 1]
type = PlaySnd
trigger1 = AnimElem = 5
value = 0, 62

[State 220, 2]
type = HitDef
trigger1 = AnimElem = 5
attr = S, NA
animtype  = Hard
damage    = Ceil(IfElse(fvar(11) * 45 < 7, 7, fvar(11) * 45)), 0
priority = 4, Hit
guardflag = MA
pausetime = 13,13
guard.pausetime = 13,13
sparkno = s7031
guard.sparkno = s7000
sparkxy = -20,-50
hitsound   = s0,61
guardsound = S6,1
ground.type = high
ground.slidetime = 16
ground.hittime = 16
guard.hittime = 10
ground.velocity = -7
air.velocity = -4,-4
air.animtype = back
getpower= ifelse(p2movetype=H,40,210), 35
givepower = 35,35
yaccel = 0.5
ID = 1098

[State 0, basics limiter]
type = Explod
triggerall = !IsHelper
trigger1 = !NumExplod(987654321)
trigger1 = movehit
trigger1 = numtarget
anim = 15999
ID = 987654321
pos = 0,0
postype = p1  ;p2,front,back,left,right
removetime = 24
