triggerall= !AILevel
triggerall = Roundstate = [2,3]
triggerall = NumExplod(90000008) || NumExplod(90000009) || NumExplod(90000007)
trigger1 = (StateNo = 450 || StateNo = 455) && animelemtime(7)>0 && MoveHit

[State -1, Super Jump Forward]
type = ChangeState
value = 10232
