;====================================
;AI CODING
;====================================


;AI Jump
[State 0, ChangeState AI Jump]
type = ChangeState
triggerall = AILevel>0 && numenemy && roundstate=2 && StateType = S  
triggerall = Ctrl = 1
trigger1 = random <10*(AIlevel ** 2 / 64.0)
trigger1 = (StateNo = 20) && Time >15
trigger2 = p2bodydist x<140
trigger2 = P2MoveType = H && P2StateType = A
trigger2 = random <20*(AIlevel ** 2 / 64.0)
trigger3 = P2BodyDist Y <0
trigger3 = P2MoveType = A
trigger3 = enemynear, Facing = Facing
trigger3 = random <30*(AIlevel ** 2 / 64.0)
trigger3 = P2BodyDist X = [10,30]
value = 40
ctrl = 0

[State -1, AI Guard]
type= changestate
triggerall = numenemy
triggerall= AILevel>0
triggerall= roundstate=2 && inguarddist
triggerall= ctrl && (stateno!=[120,155])&& !(enemynear,ctrl)
triggerall = enemynear, time > 5
trigger1= !(enemynear,hitdefattr=SCA,AT) && (enemynear,time<120)
trigger2= random < 14*(AIlevel ** 2 / 64.0) && (enemynear,hitdefattr=SCA,NA)
trigger3= random < 28*(AIlevel ** 2 / 64.0) && (enemynear,hitdefattr=SCA,SA)
trigger4= random < 92*(AIlevel ** 2 / 64.0) && (enemynear,hitdefattr=SCA,HA)
value=120

[State -1, AI Guard fix]
Type=Assertspecial
Triggerall=StateNo!=[120,155]
Trigger1=AILevel>0
flag=noairguard
flag2=nocrouchguard
flag3=nostandguard

[State -1, Fall Recovery AI]
type=ChangeState
value= ifelse((pos y>=-20), 5200, 5210)
triggerall = numenemy
triggerall= AILevel>0 
triggerall= RoundState=2 && alive
triggerall= StateNo=5050 && canrecover
trigger1= vel y>=-1 && ceil(random<=50*(AILevel**2/64.0))

;AI Zetto Counter
[State -1, AI Zetto counter]
type= ChangeState
trigger1= AILevel>0 && numenemy && roundstate=2 && statetype!=A && power>=1000
trigger1= stateno=[150, 155]
trigger1= random < 25*(AIlevel ** 2 / 64.0)
trigger1= (p2bodydist x=[0,50]) && (life<.5*lifemax)
trigger1 = CTRL = 0
value=750

;Air Zetto Counter
[State -1, AI Air Zetto counter]
type= ChangeState
trigger1= AILevel>0 && numenemy && roundstate=2 && statetype=A && power>=1000
trigger1= stateno=[150, 155]
trigger1= random < 25*(AIlevel ** 2 / 64.0)
trigger1= (p2bodydist x=[0,50]) && (life<.5*lifemax)
trigger1 = CTRL = 0
value=760

[State -1, AI Focus Attack]
type = ChangeState
triggerall= AILevel>0 && numenemy && roundstate = 2 && (stateno !=[1300,1302]) && stateno != 106 && statetype = S && (enemynear, Movetype != A)
triggerall= (p2bodydist x = [45,135]) && (p2bodydist y = [ -70, 0]) && (p2statetype != L) && (enemynear, vel y >= 0)
triggerall= (enemynear, const(size.head.pos.y) <= -40) || (enemynear, statetype != A)
trigger1 = ctrl && random<25*(AIlevel ** 2 / 64.0)
trigger2 = ctrl && random<125*(AIlevel ** 2 / 64.0)
trigger2 = P2BodyDist X = [-20,60]
trigger2 = P2MoveType = A && (p2bodydist y = [ -70, 0])
trigger2 = enemynear, HitDefAttr = SCA, NA
value = 1300

;AI Power Charge
[State -1, AI Power Charge]
type=ChangeState
triggerall= AILevel>0 && numenemy && roundstate=2 && statetype!=A
triggerall= power<const(data.power) && enemynear,Movetype!=A && !(enemynear,ctrl)
triggerall=  power < const(data.power) && power < powermax
triggerall= !inguarddist && random < 200*(AIlevel ** 2 / 64.0) 
triggerall = stateno != [900,901]
triggerall = prevstateno != [900,901]
triggerall= ctrl
trigger1=(enemynear,Movetype=H||enemynear,statetype=L)
trigger2=enemynear,vel x<0
trigger3=enemynear,stateno=[120,155]
trigger4=enemynear,Movetype=I
value=900