;==============================================================================================
;===================================<DIRECTIONAL COMMANDS>=====================================
;==============================================================================================

;==============================================================================================
;These are required for the system to function; they are active whenever the specified direction
;is currently being input, and disappear as soon as they are released (via a series of RemoveExplods
;at the bottom of the Buffering system code block). They are used by the system to detect directional
;releases, but can also be used outside of the Buffering system code block to detect when a specific
;direction is being input or held down.
;==============================================================================================

;==============================================================================================
;==============================================================================================
;=============================<End of EXPLODsive Buffering System>=============================
;==============================================================================================
;==============================================================================================

;This is not a move, but it sets up var(36) to be set to a certain value if conditions are met
;for a combo into a special move or super (used below).
;Since a lot of moves rely on the same conditions, this reduces
;redundant logic.
[State -1, Combo condition Reset]
type = Null
trigger1 = 1 || var(36) := var(36) - (var(36)&256) ;Reset Special Cancel
trigger1 = 1 || var(36) := var(36) - (var(36)&128) ;Reset Super Cancel
trigger1 = 1 || var(36) := var(36) - (var(36)&512) ;Reset Sweep Cancel
trigger1 = 1 || var(36) := var(36) - (var(36)&1024) ;Reset Godly Ki Blast Cancel
trigger1 = 1 || var(36) := var(36) - (var(36)&8192) ;Reset Divekick Backflip Cancel


[State -1, Set Up Standard Cancel Bits]
type = Null
;Cancel From Normals
trigger1 = (var(36)&256) = 0
trigger1 = stateno = [200,440] ;Ground Normals
trigger1 = movecontact
trigger1 = 1 || var(36) := var(36) + 256
trigger2 = (var(36)&256) = 0
trigger2 = (stateno = 600) || (stateno = 610) || (stateno = 620) || (stateno = 630) || (stateno = 640) ;Air Normals
trigger2 = movecontact
trigger2 = 1 || var(36) := var(36) + 256
;Cancel From Specials
trigger3 = (var(36)&128) = 0
trigger3 = stateno = 1001 && movecontact ||(stateno = [1150,1152]) && Animelemtime(3) >= 0 || numhelper(1011) && AnimElemTime(5) >= 0 && stateno = 1050 
trigger3 = var(36) := var(36) + 128

[State -1, Set Up Extra Cancel Bits]
type = Null
;Cancel From Godly Ki Blast
trigger1 = (var(36)&1024) = 0
trigger1 = stateno = 1050 
trigger1 = AnimElemtime(6) >= 0
trigger1 = 1 || var(36) := var(36) + 1024
;Cancel From Sweep
trigger2 = (var(36)&512) = 0
trigger2 = stateno = 450
trigger2 = movecontact
trigger2 = 1 || var(36) := var(36) + 512
;Cancel From Backflip on Divekick
trigger3 = (var(36)&8192) = 0
trigger3 = stateno = 1103 && (var(36)&2048) != 0
trigger3 = var(36) := var(36) + 8192



;==============================================================================================
;==========================================<GUARDING>==========================================
;==============================================================================================
 
;==============================================================================================
;Here, we override the MUGEN's default guard system, and add our own triggers. This will ensure
;that the player can always block as long as they are holding a direction away from the opponent.
;This block of code also adds "chicken guarding", which is allowing the player to air guard by holding
;not only back, but down-back and up-back.
 
;It is also recommended that you also override the guard states (120, 130, 131, 132, 140, 150, 151, 152, 154, 155)
;with an updated version that uses the EXPLODsive buffering system. A copy of those fixed states
;can be found in this character, and also in the release thread (here:PUT LINK HERE).
;==============================================================================================
 
[State -1, AssertSpecial: NoAirGuard]
type = AssertSpecial
trigger1 = P2DisT x < -12 && StateType = A
trigger2 =  !NumExplod(90000004) && !NumExplod(90000006) && !NumExplod(90000001) && !NumExplod(90000003) && !NumExplod(90000007) && !NumExplod(90000009)
trigger3 = StateNo = 105 ||StateNo = 110 || StateNo = 115 || StateNo = 111;5.1
flag = NoAirGuard
ignoreHitPause = 0

     
;The first state controller disables MUGEN's normal guard system if any of of these scenarios occur.
[State -1, AssertSpecial: No StandGuard and NoCrouchGuard]
type = AssertSpecial
triggerAll = !AILevel
trigger1 = P2dist x < -12 && StateType != A
trigger2 = NumExplod(94646464) || NumExplod(92468246)
trigger3 = command = "holdback" && command = "holdfwd" || command = "holdup" && command = "holddown"
flag = NoStandGuard
flag2 = NoCrouchGuard
ignoreHitPause = 0


;===========================================================================
; HYPERS
;===========================================================================



;EMOTION EXIT (Zamasu Heal)
[State -1, Zamasu Heal]
type = ChangeState
triggerall = !var(9) ;Zamasu Not on stage
triggerall = enemy, name != "Saibamen Z2" && authorname = "Team Z2"
triggerall = TeamMode != Simul
triggerall = enemyNear,TeamMode != Simul
triggerall= !AILevel
triggerall = var(50) ;Judgement Mode on
triggerall = NumExplod(90012602)
triggerall = NumExplod(90000210) && NumExplod(90000240) || NumExplod(90000215) && NumExplod(90000245)
triggerall = statetype != A  && !WinKo
triggerall = stateno != 4100
trigger1 = Ctrl
trigger2 = stateno=900
value = 4100


;EMOTION Activate (Judgement Mode)
[State -1, Judgement Mode Activate]
type = ChangeState
triggerall = enemy, name != "Saibamen Z2" && authorname = "Team Z2"
triggerall = TeamMode != Simul
triggerall = enemyNear,TeamMode != Simul
triggerall= !AILevel
triggerall = var(50)=0 ;No Judgement mode
triggerall = NumExplod(90012602)
triggerall = NumExplod(90000210) && NumExplod(90000240) || NumExplod(90000215) && NumExplod(90000245)
triggerall = statetype != A  && !WinKo
triggerall = power >= 2000 && stateno != 4000
trigger1 = Ctrl
trigger2 = stateno=900
value = 4000

;Fierce God Rush (Finisher) (236236KKK)
[State -1, Fierce God Rush (Finisher)]
type = Changestate
triggerall= !AIlevel
triggerall = ((ifElse(P2DisT x < -12, Facing = -1, Facing = 1) && NumExplod(90030016)) || (ifElse(P2DisT x < -12, Facing = 1, Facing = -1) && NumExplod(90030114)))
triggerall = NumExplod(90000230) && NumExplod(90000240) && NumExplod(90000250)
triggerall = statetype != A && !WinKo
triggerall = power >= cond(var(50),2000,3000)
trigger1 = ctrl 
trigger2 = (var(36)&128) != 0 ;Super Cancel On
trigger3 = (var(36)&256) != 0 ;Special Cancel On
value = 4500



;===========================================================================
; SUPERS
;===========================================================================

;Devout Alliance (214214K)
[State -1, Devout Alliance]
type = ChangeState
triggerall = var(50) >= 1 ;Emo On
triggerall = !var(9) ;Zamasu var
triggerall = !AILevel
triggerall = ((ifElse(P2DisT x < -12, Facing = -1, Facing = 1) && (NumExplod(90030101) || NumExplod(90030114))) || (ifElse(P2DisT x < -12, Facing = 1, Facing = -1) && (NumExplod(90030016) || NumExplod(90030003))))
triggerall =  NumExplod(90000230) || NumExplod(90000235) || NumExplod(90000240) || NumExplod(90000245) || NumExplod(90000250) || NumExplod(90000255)
triggerall = StateType != A  && !WinKo && RoundState = 2 && StateNo != 4300
triggerall = power >= 1000
trigger1 = Ctrl
trigger2 = stateno = [200,440]
trigger2 = (var(36)&128) != 0 ;Super Cancel On
trigger3 = (var(36)&256) != 0 ;Special Cancel On
value = 4300


;Holy Light Grenade Lvl 2 (236236PP)
[State -1,Holy Light Grenade Lvl 2]
type = ChangeState
triggerall= AILevel<=0
triggerall = ifElse(Facing = 1,(NumExplod(90030016) || NumExplod(90030003)),(NumExplod(90030114) || NumExplod(90030101)))
triggerall = (cond(NumExplod(90000200), 1, 0) + cond(NumExplod(90000210), 1, 0) + cond(NumExplod(90000220), 1, 0) >= 2) || (cond(NumExplod(90000205), 1, 0) + cond(NumExplod(90000215), 1, 0) + cond(NumExplod(90000225), 1, 0) >= 2)
triggerall = !WinKo
triggerall = (power >= 2000)
triggerall = stateno != 2205
triggerall = numhelper(1375) = 0 && numhelper(1376) = 0
trigger1 = ctrl
trigger2 = stateno = [200,440]
trigger2 = (var(36)&128) != 0 ;Super Cancel On
trigger3 = (var(36)&256) != 0 ;Special Cancel On
trigger4 = (var(36)&8192) != 0 ;Backflip Cancel On
value = 2205



;Divine Retribution (236236KK)
[State -1, Divine Retribution]
