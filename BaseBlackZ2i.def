; Definition file for Goku Black Base Z2i By EXDoragon, Reimagined by Junny

;====================================================================
; PLAYER INFORMATION

[Info]
name = "Base Black Z2i"
displayname = "Black"
versiondate = 07,14,2013
mugenversion = 1.0
author = "Team Z2" ;For Compatibility
pal.defaults = 1,2,3,4,5,6,7
localcoord = 320,240

;Some new SSJ ingame sprites and base
;form Miniportrait are made by Kercy (Fixed by EXDoragon).
;(Twitter: @KdeKercy)
 
;Base Form Sprite edit by HB Production and SSJ Miniportrait
;is made by Kercy
;Skirt and earring addition to base sprites done by Bob Lee and Switch, redone sprites on light grenade and god slicer by Yoshin2222
;Zamasu Sprite contributions by Leidan, Skipper, Denis
;(Twitter: @HB_Production)
;(Youtube: https://www.youtube.com/c/HBProductionMugen )

;Both Base (Fixed by EXDoragon) and SSJ Rockportraits are made by Sumguy
;(Twitter: @supasumguy)
;(Base actually had Rose hair, so it was edited by HB Prodution)

;Base Winportrait by Pansh
;(Twitter: @PanshPixel)

;SSJ WinPortrait by TheGuzyo
;(Twitter: @theguzyo)


;====================================================================
;FILES FOR THE PLAYER

[Files]
sprite  = files/Base.sff
anim    = files/animation.air
sound   = files/goku-jap-bl.snd
cmd     = files/command.mfg
cns     = states/constants.cns
st	= states/system.cns
st2	= states/helpers.cns
st3	= states/state-2-3.cns
st4	= states/override.cns
st5       = states/normals.cns
st6	= states/specials.cns
st7	= states/supers.cns
st8 = states/emotion.cns
st9	= config.txt
st0 = states/zamasu.cns
st1	= states/finishers.cns
stcommon = common1.cns

;====================================================================
;PALETTES
; Maps character selection buttons to palette numbers.
[Palette Keymap]
x = 4 ;Press button X to select palette 1, etc.
y = 5
z = 6
a = 1
b = 2
c = 3
x2 = 10 ;Hold Start and press button X for palette 7, etc.
y2 = 11
z2 = 12
a2 = 7
b2 = 8
c2 = 9


